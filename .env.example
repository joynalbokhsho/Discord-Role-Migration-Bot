# Discord Role Migration Bot — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Never commit .env to version control (it's in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# REQUIRED — Discord Bot Credentials
# Get these from https://discord.com/developers/applications
# ─────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Guild-specific command deployment
# Set this to your server ID for instant slash command updates (dev/testing).
# Leave blank to deploy commands globally (takes up to 1 hour to propagate).
# ─────────────────────────────────────────────────────────────
GUILD_ID=your_guild_id_here

# ─────────────────────────────────────────────────────────────
# OPTIONAL — Default log channel for migration reports
# The channel ID where migration start/progress/complete embeds are sent.
# Can also be set per-server via the /set-log-channel command.
# ─────────────────────────────────────────────────────────────
LOG_CHANNEL_ID=

# ─────────────────────────────────────────────────────────────
# DATABASE — SQLite file path (relative to project root)
# The database is created automatically on first run.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=./database/migrations.db

# ─────────────────────────────────────────────────────────────
# RATE LIMITING — Tuning for large servers
#
# RATE_LIMIT_DELAY — Milliseconds between each role assignment API call.
#   Discord's per-guild role bucket allows ~10 req/10s.
#   Recommended: 2500 (safe, ~1 req/2.5s, virtually zero rate-limit warnings)
#   Minimum:     1000 (aggressive, may trigger occasional rate limits)
#
# BATCH_SIZE — Members processed per event-loop tick (default: 10)
#
# MAX_RETRIES — Retry attempts for a failed role assignment (default: 3)
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_DELAY=2500
BATCH_SIZE=10
MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────
# LOGGING
# Console + file log level: error | warn | info | debug
# Daily rotating log files are saved to ./logs/
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# WEBHOOK LOGGING (optional)
# Discord webhook URL for forwarding bot logs to a channel.
# Leave blank to disable.
# ─────────────────────────────────────────────────────────────
WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────
# NODE ENVIRONMENT
# Use "production" for live bots, "development" for local testing.
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
